# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/buddyscript

# JWT Secret 
JWT_SECRET=change-this-to-a-secure-32-plus-char-secret

# CORS Configuration 
CORS_ORIGIN=http://localhost:3000,http://localhost:3001
APP_BASE_URL=http://localhost:5000

# Storage Provider: local | cloudinary
STORAGE_PROVIDER=local

# Cloudinary Configuration 
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Redis 
REDIS_URL=

# Production-hardening options
ENABLE_LEGACY_PAGE_PAGINATION=false
CACHE_TTL_SECONDS=60
ENABLE_MEDIA_JOB_WORKER=true
COOKIE_SAME_SITE=lax
JSON_BODY_LIMIT=2mb
URLENCODED_BODY_LIMIT=2mb
